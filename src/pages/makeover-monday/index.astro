---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";

const allEntries = (await getCollection("makeover_monday"))
  .filter((e) => !e.data.draft)
  .sort((a, b) => {
    if (b.data.year !== a.data.year) return b.data.year - a.data.year;
    return b.data.week - a.data.week;
  });

const byYear: Record<number, typeof allEntries> = {};
for (const entry of allEntries) {
  if (!byYear[entry.data.year]) byYear[entry.data.year] = [];
  byYear[entry.data.year].push(entry);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const gradients = [
  "linear-gradient(135deg,#8b5cf6,#14b8a6)",
  "linear-gradient(135deg,#14b8a6,#3b82f6)",
  "linear-gradient(135deg,#f472b6,#8b5cf6)",
  "linear-gradient(135deg,#3b82f6,#f472b6)",
  "linear-gradient(135deg,#eab308,#14b8a6)",
  "linear-gradient(135deg,#0f766e,#0f172a)",
  "linear-gradient(135deg,#14b8a6,#8b5cf6)",
  "linear-gradient(135deg,#f97316,#eab308)",
];

---

<BaseLayout title="Makeover Monday — JuanFe">
  <Nav />
  <main class="aurora-bg min-h-screen pt-20">
    <div class="relative z-10 mx-auto max-w-6xl px-6 py-16">

      <!-- Header -->
      <div class="mb-14">
        <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-aurora-purple);">Data Visualization</p>
        <h1 class="text-5xl font-bold" style="font-family: var(--font-display); color: var(--color-text);">Makeover Monday</h1>
        <p class="mt-3 text-lg max-w-xl" style="color: var(--color-text-muted);">
          Reimaginando datasets públicos cada semana. Mismo dataset, otra perspectiva, otra historia.
        </p>
      </div>

      <!-- Year sections -->
      {years.map((year) => (
        <section class="mb-20">
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-3xl font-bold" style="font-family: var(--font-display); color: var(--color-text);">{year}</h2>
            <div class="flex-1 h-px" style="background: var(--color-border);" />
            <span class="text-xs font-medium" style="color: var(--color-text-muted);">
              {byYear[year].length} visualización{byYear[year].length !== 1 ? "es" : ""}
            </span>
          </div>

          <div class="viz-grid">
            {byYear[year].map((entry) => {
              const g  = gradients[entry.data.week % gradients.length];
              const wk = String(entry.data.week).padStart(2, "0");
              return (
                <button
                  class="viz-card"
                  data-slug={entry.id}
                  data-title={entry.data.title}
                  data-week={String(entry.data.week)}
                  data-year={String(entry.data.year)}
                  data-image={entry.data.image ?? ""}
                  data-gradient={g}
                  data-description={entry.data.description ?? ""}
                  aria-label={`W${wk} · ${entry.data.title}`}
                >
                  <div class="viz-inner">
                    {entry.data.image
                      ? <img src={entry.data.image} alt={entry.data.title} class="viz-img" loading="lazy" />
                      : <div class="viz-img" style={`background: ${g};`} />
                    }
                    <div class="viz-info">
                      <span class="viz-week-badge">W{wk}</span>
                      <p class="viz-title-overlay">{entry.data.title}</p>
                    </div>
                  </div>
                </button>
              );
            })}
          </div>
        </section>
      ))}

    </div>
  </main>

  <!-- Card popup -->
  <div id="lb" class="lb" aria-hidden="true" role="dialog" aria-modal="true">
    <div id="lb-backdrop" class="lb-backdrop" />
    <div id="lb-frame" class="lb-frame">
      <button id="lb-close" class="lb-close" aria-label="Cerrar">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
      <div class="lb-header">
        <span id="lb-badge" class="lb-badge" />
        <p id="lb-title" class="lb-title" />
      </div>
      <div class="lb-body">
        <div id="lb-media" class="lb-media" />
        <div class="lb-info">
          <p id="lb-desc" class="lb-desc" />
          <a id="lb-link" href="#" class="lb-link">Ver detalles →</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const lb       = document.getElementById("lb")!;
  const backdrop = document.getElementById("lb-backdrop")!;
  const closeBtn = document.getElementById("lb-close")!;
  const media    = document.getElementById("lb-media")!;
  const badge    = document.getElementById("lb-badge")!;
  const titleEl  = document.getElementById("lb-title")!;
  const linkEl   = document.getElementById("lb-link") as HTMLAnchorElement;

  const descEl = document.getElementById("lb-desc")!;

  function openLb(card: HTMLButtonElement) {
    const { slug, title, week, year, image, gradient, description } = card.dataset as Record<string, string>;
    const wk = week.padStart(2, "0");

    media.innerHTML = image
      ? `<img src="${image}" alt="${title}" class="lb-img" style="border-radius:12px;" />`
      : `<div class="lb-img" style="background:${gradient};border-radius:12px;"></div>`;

    badge.textContent   = `W${wk} · ${year}`;
    titleEl.textContent = title;
    descEl.textContent  = description || "";
    linkEl.href         = `/makeover-monday/${slug}`;

    lb.classList.add("open");
    lb.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeLb() {
    lb.classList.remove("open");
    lb.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".viz-card").forEach((c) => {
    c.addEventListener("click", () => openLb(c));
  });
  lb.addEventListener("click", closeLb);
  document.getElementById("lb-frame")!.addEventListener("click", (e) => e.stopPropagation());
  closeBtn.addEventListener("click", (e) => { e.stopPropagation(); closeLb(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeLb(); });
</script>

<style>
  /* ── Masonry grid (Pinterest style) ───────────────── */
  .viz-grid {
    columns: 4;
    column-gap: 8px;
  }

  @media (max-width: 900px) {
    .viz-grid { columns: 3; }
  }
  @media (max-width: 480px) {
    .viz-grid { columns: 2; }
  }

  /* ── Card ──────────────────────────────────────────── */
  .viz-card {
    break-inside: avoid;
    display: block;
    width: 100%;
    margin-bottom: 8px;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    border: none;
    padding: 0;
    background: var(--color-surface-2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .viz-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.28);
    z-index: 1;
  }
  .viz-inner {
    width: 100%;
    position: relative;
  }
  .viz-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }
  .viz-card:hover .viz-img {
    transform: scale(1.06);
  }
  .viz-info {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.05) 45%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .viz-card:hover .viz-info { opacity: 1; }

  .viz-week-badge {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 2px;
  }
  .viz-title-overlay {
    font-size: 10px;
    font-weight: 600;
    color: white;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Lightbox ──────────────────────────────────────── */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .lb.open {
    pointer-events: all;
    opacity: 1;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    pointer-events: none;
  }
  /* ── Card frame ───────────────────────────────────── */
  .lb-frame {
    position: relative;
    z-index: 1;
    width: min(680px, 92vw);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.45);
    transform: scale(0.94) translateY(12px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .lb.open .lb-frame {
    transform: scale(1) translateY(0);
  }
  .lb-close {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
    z-index: 2;
  }
  .lb-close:hover {
    color: var(--color-text);
    background: var(--color-border);
  }

  /* Card header */
  .lb-header {
    padding: 16px 44px 12px 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .lb-badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-aurora-purple);
    display: block;
    margin-bottom: 4px;
  }
  .lb-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    font-family: var(--font-display);
    line-height: 1.3;
  }

  /* Card body: image left + info right */
  .lb-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .lb-media {
    border-right: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 20px;
    display: flex;
    align-items: center;
  }
  .lb-img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    border-radius: 12px;
    max-height: 220px;
  }
  .lb-info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 16px;
    gap: 12px;
  }
  .lb-desc {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
  }
  .lb-link {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    background: var(--color-aurora-purple);
    border-radius: 8px;
    padding: 8px 14px;
    text-decoration: none;
    text-align: center;
    transition: opacity 0.15s;
    align-self: flex-start;
  }
  .lb-link:hover { opacity: 0.85; }

  @media (max-width: 480px) {
    .lb-body { grid-template-columns: 1fr; }
    .lb-media { border-right: none; border-bottom: 1px solid var(--color-border); }
    .lb-img { max-height: 200px; }
  }
</style>
