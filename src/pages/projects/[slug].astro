---
import { getCollection, render } from "astro:content";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import PostLayout from "../../layouts/PostLayout.astro";
import MagazineLayout from "../../layouts/MagazineLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, date, domain, level, level_name, flags, stack,
        complexity_breakdown, summary, github, demo, layout } = project.data;
---

{layout === "magazine" ? (
  <MagazineLayout title={title} description={description}>
    <Content />
  </MagazineLayout>
) : (
  <ProjectLayout
    title={title}
    description={description}
    date={date}
    domain={domain}
    level={level}
    level_name={level_name}
    flags={flags}
    stack={stack}
    complexity_breakdown={complexity_breakdown}
    summary={summary}
    github={github}
    demo={demo}
  >
    <Content />
  </ProjectLayout>
)}
