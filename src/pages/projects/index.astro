---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const domainLabel: Record<string, string> = {
  "data-engineering": "Data Engineering",
  "machine-learning": "Machine Learning",
  "ai": "AI",
  "analytics": "Analytics",
  "web": "Web",
  "mobile": "Mobile",
};

const domainGradient: Record<string, string> = {
  "data-engineering": "linear-gradient(135deg, #14b8a6 0%, #3b82f6 100%)",
  "machine-learning": "linear-gradient(135deg, #8b5cf6 0%, #f472b6 100%)",
  "ai":               "linear-gradient(135deg, #f472b6 0%, #8b5cf6 100%)",
  "analytics":        "linear-gradient(135deg, #3b82f6 0%, #14b8a6 100%)",
  "web":              "linear-gradient(135deg, #14b8a6 0%, #8b5cf6 100%)",
  "mobile":           "linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%)",
};

const domainColor: Record<string, string> = {
  "data-engineering": "#14b8a6",
  "machine-learning": "#8b5cf6",
  "ai":               "#f472b6",
  "analytics":        "#3b82f6",
  "web":              "#14b8a6",
  "mobile":           "#8b5cf6",
};

const levelDot: Record<number, string> = {
  1: "🟢", 2: "🔵", 3: "🟡", 4: "🟠", 5: "🔴",
};

const flagLabel: Record<string, string> = {
  "ai-ml":             "🤖 IA/ML",
  "multiplatform":     "📱 Multi",
  "advanced-security": "🔐 Seg",
  "realtime":          "⚡ RT",
  "data-intensive":    "📊 Data",
  "cloud-native":      "☁️ Cloud",
  "payments":          "💰 Pagos",
  "high-concurrency":  "🌍 Concurrencia",
};

const activeDomains = [...new Set(projects.map((p) => p.data.domain))];
---

<PageLayout title="Proyectos">
  <div class="mx-auto max-w-5xl px-6 py-16">

    <header class="mb-10">
      <p class="mb-2 text-sm font-medium" style="color: var(--color-aurora-teal);">Trabajo</p>
      <h1 class="text-4xl font-bold md:text-5xl" style="font-family: var(--font-display); color: var(--color-text);">
        Proyectos
      </h1>
      <p class="mt-4 text-lg" style="color: var(--color-text-muted);">
        Apps web, mobile, modelos de ML, pipelines de datos y aplicaciones con IA.
      </p>
    </header>

    <div class="flex flex-wrap gap-2 mb-10" id="filters">
      <button class="filter-btn active" data-filter="all">Todos</button>
      {activeDomains.map((domain) => (
        <button class="filter-btn" data-filter={domain}>{domainLabel[domain]}</button>
      ))}
    </div>

    {projects.length === 0 ? (
      <p style="color: var(--color-text-muted);">Próximamente...</p>
    ) : (
      <div class="projects-grid" id="projects-grid">
        {projects.map((project) => {
          const color    = domainColor[project.data.domain];
          const gradient = domainGradient[project.data.domain];
          const dims = [
            { label: "Data",   value: project.data.complexity_breakdown.data },
            { label: "Infra",  value: project.data.complexity_breakdown.infra },
            { label: "ML",     value: project.data.complexity_breakdown.ml },
            { label: "Integ.", value: project.data.complexity_breakdown.integration },
          ];
          return (
            <div class="card-wrapper" data-domain={project.data.domain}>
              <div class="card-inner">

                {/* ── FRENTE ── */}
                <div class="card-face card-front" style="background: var(--color-surface); border: 1px solid var(--color-border);">
                  <div class="card-hero">
                    {project.data.image
                      ? <img src={project.data.image} alt={project.data.title} class="card-hero-img" />
                      : <div class="card-hero-gradient" style={`background: ${gradient};`} />
                    }
                    <span class="card-domain-badge" style={`background: color-mix(in srgb, ${color} 25%, rgba(0,0,0,0.6)); color: white;`}>
                      {domainLabel[project.data.domain]}
                    </span>
                  </div>
                  <div class="card-body">
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-xs" style="color: var(--color-text-muted);">
                        {levelDot[project.data.level]} {project.data.level_name}
                      </span>
                      <span class="flip-hint">detalle →</span>
                    </div>
                    <h2 class="card-title" style="font-family: var(--font-display); color: var(--color-text);">
                      {project.data.title}
                    </h2>
                    <p class="card-desc" style="color: var(--color-text-muted);">
                      {project.data.description}
                    </p>
                    <div class="front-stack">
                      {project.data.stack.slice(0, 4).map((tech) => (
                        <span class="tech-tag">{tech}</span>
                      ))}
                      {project.data.stack.length > 4 && (
                        <span class="tech-tag" style="color: var(--color-text-muted);">+{project.data.stack.length - 4}</span>
                      )}
                    </div>
                  </div>
                  <a
                    href={`/projects/${project.id}`}
                    class="front-cta"
                    style={`background: ${color};`}
                  >
                    Ver proyecto →
                  </a>
                </div>

                {/* ── DORSO ── */}
                <div class="card-face card-back" style={`border: 1px solid ${color}22;`}>
                  {/* Fondo con gradiente sutil */}
                  <div class="back-bg" style={`background: ${gradient}; opacity: 0.07;`} />

                  <div class="card-back-body">
                    {/* Header */}
                    <div class="back-header">
                      <div>
                        <p class="back-label" style={`color: ${color};`}>{domainLabel[project.data.domain]}</p>
                        <h3 class="back-title" style="color: var(--color-text);">{project.data.title}</h3>
                      </div>
                      <div class="score-badge" style={`border-color: ${color}44; color: ${color};`}>
                        <span class="score-num">{project.data.score}</span>
                        <span class="score-den">/12</span>
                      </div>
                    </div>

                    {/* Mini chart */}
                    <div class="chart-section">
                      {dims.map(({ label, value }) => (
                        <div class="chart-row">
                          <span class="chart-label">{label}</span>
                          <div class="chart-track">
                            <div
                              class="chart-fill"
                              style={`width: ${(value / 3) * 100}%; background: ${color};`}
                            />
                          </div>
                          <span class="chart-value" style={`color: ${value > 0 ? color : 'var(--color-text-muted)'};`}>
                            {value}/3
                          </span>
                        </div>
                      ))}
                    </div>

                    {/* Stack */}
                    <div>
                      <p class="tags-label">Stack</p>
                      <div class="tags-row">
                        {project.data.stack.map((tech) => (
                          <span class="tech-tag">{tech}</span>
                        ))}
                      </div>
                    </div>

                    {/* Flags */}
                    {project.data.flags.length > 0 && (
                      <div>
                        <p class="tags-label">Habilidades</p>
                        <div class="tags-row">
                          {project.data.flags.map((flag) => (
                            <span class="flag-tag" style={`color: ${color}; background: ${color}14; border-color: ${color}30;`}>
                              {flagLabel[flag]}
                            </span>
                          ))}
                        </div>
                      </div>
                    )}

                    {/* Links */}
                    {(project.data.github || project.data.demo) && (
                      <div class="back-links">
                        {project.data.github && (
                          <a href={project.data.github} target="_blank" rel="noopener" class="btn-secondary">GitHub</a>
                        )}
                        {project.data.demo && (
                          <a href={project.data.demo} target="_blank" rel="noopener" class="btn-secondary">Demo</a>
                        )}
                      </div>
                    )}
                  </div>
                </div>

              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</PageLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
  }

  /* Flip */
  .card-wrapper {
    height: 300px;
    perspective: 1200px;
    cursor: pointer;
  }
  .card-wrapper.hidden { display: none; }

  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0.2, 0.2, 1);
  }
  .card-wrapper.flipped .card-inner { transform: rotateY(180deg); }

  .card-face {
    position: absolute;
    inset: 0;
    border-radius: 1.5rem;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .card-back { transform: rotateY(180deg); background: var(--color-surface); }

  /* Front hero */
  .card-hero {
    position: relative;
    height: 130px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-hero-img { width: 100%; height: 100%; object-fit: cover; }
  .card-hero-gradient { width: 100%; height: 100%; }
  .card-domain-badge {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    padding: 0.15rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    backdrop-filter: blur(6px);
  }

  /* Front body */
  .card-body { padding: 0.75rem 1.25rem; }
  .card-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }
  .card-desc {
    font-size: 0.78rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .front-cta {
    position: absolute;
    bottom: 0.75rem;
    right: 1rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-decoration: none;
    color: white;
    padding: 0.35rem 0.85rem;
    border-radius: 0.65rem;
    transition: opacity 0.15s;
  }
  .front-cta:hover { opacity: 0.85; }

  .front-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.6rem;
  }

  .flip-hint {
    font-size: 0.62rem;
    color: var(--color-text-muted);
    opacity: 0.5;
    user-select: none;
  }

  /* Back */
  .back-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .card-back-body {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.25rem;
    gap: 0.75rem;
  }

  .back-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .back-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.1rem; }
  .back-title { font-size: 0.9rem; font-weight: 700; font-family: var(--font-display); line-height: 1.2; color: var(--color-text); }

  .score-badge {
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: 1px;
    border: 1px solid;
    border-radius: 0.75rem;
    padding: 0.25rem 0.6rem;
  }
  .score-num { font-size: 1.1rem; font-weight: 800; font-family: var(--font-display); line-height: 1; }
  .score-den { font-size: 0.65rem; font-weight: 500; opacity: 0.7; }

  /* Mini bar chart */
  .chart-section { display: flex; flex-direction: column; gap: 0.3rem; }
  .chart-row { display: flex; align-items: center; gap: 0.5rem; }
  .chart-label { width: 2.25rem; font-size: 0.62rem; color: var(--color-text-muted); flex-shrink: 0; }
  .chart-track {
    flex: 1;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-surface-2);
    overflow: hidden;
  }
  .chart-fill { height: 100%; border-radius: 9999px; transition: width 0.4s ease; }
  .chart-value { width: 1.8rem; font-size: 0.62rem; font-weight: 600; text-align: right; flex-shrink: 0; }

  /* Tags */
  .tags-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.3rem;
  }
  .tags-row { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .tech-tag {
    padding: 0.1rem 0.5rem;
    border-radius: 0.35rem;
    font-size: 0.65rem;
    font-family: monospace;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }
  .flag-tag {
    padding: 0.1rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    border: 1px solid;
  }

  /* Back buttons */
  .back-links { display: flex; gap: 0.5rem; margin-top: auto; width: 100%; }
  .btn-primary {
    display: block;
    text-align: center;
    padding: 0.45rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: white;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-secondary {
    flex: 1;
    text-align: center;
    padding: 0.35rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.72rem;
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: color 0.15s;
  }
  .btn-secondary:hover { color: var(--color-text); }

  /* Filters */
  .filter-btn {
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-btn:hover { color: var(--color-text); border-color: var(--color-text-muted); }
  .filter-btn.active { background: var(--color-text); color: var(--color-bg); border-color: var(--color-text); }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".card-wrapper").forEach((card) => {
    card.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) return;
      card.classList.toggle("flipped");
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      document.querySelectorAll<HTMLButtonElement>(".filter-btn").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      document.querySelectorAll<HTMLElement>(".card-wrapper").forEach((card) => {
        const match = filter === "all" || card.dataset.domain === filter;
        card.classList.toggle("hidden", !match);
        if (!match) card.classList.remove("flipped");
      });
    });
  });
</script>
