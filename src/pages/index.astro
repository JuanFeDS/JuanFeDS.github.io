---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const allProjects = (await getCollection("projects")).filter((p) => !p.data.draft);
const n = allProjects.length || 1;

// Level distribution
const levelName: Record<number, string> = {
  1: "Standalone Script",
  2: "Static App",
  3: "Basic Backend",
  4: "Distributed System",
  5: "Complex Platform",
};
const levelDist = [1, 2, 3, 4, 5].map((level) => ({
  level,
  count: allProjects.filter((p) => p.data.level === level).length,
}));
const maxLevelCount = Math.max(...levelDist.map((l) => l.count), 1);

const levelColor: Record<number, string> = {
  1: "var(--level-1)", 2: "var(--level-2)", 3: "var(--level-3)",
  4: "var(--level-4)", 5: "var(--level-5)",
};
const levelDesc: Record<number, string> = {
  1: "Nivel 1 · Standalone Script",
  2: "Nivel 2 · Static App",
  3: "Nivel 3 · Basic Backend",
  4: "Nivel 4 · Distributed System",
  5: "Nivel 5 · Complex Platform",
};

// Matrix: niveles × dimensiones de complejidad (siempre 5 niveles)
const matrixDims = [
  { key: "architecture",   emoji: "🧱", short: "Arch" },
  { key: "data",           emoji: "📊", short: "Data" },
  { key: "infrastructure", emoji: "⚙️", short: "Infra" },
  { key: "ai",             emoji: "🤖", short: "AI"   },
];
const projectMatrix = [1, 2, 3, 4, 5].map((level) => {
  const levelProjects = allProjects.filter((p) => p.data.level === level);
  const n = levelProjects.length || 1;
  return {
    level,
    count: levelProjects.length,
    cells: matrixDims.map(({ key }) => ({
      avg: levelProjects.length > 0
        ? +(levelProjects.reduce((s, p) => s + (p.data.complexity_breakdown as Record<string, number>)[key], 0) / n).toFixed(1)
        : null,
    })),
  };
});


const domainLabel: Record<string, string> = {
  "data-engineering": "Data Engineering",
  "machine-learning": "Machine Learning",
  "ai": "AI",
  "analytics": "Analytics",
  "web": "Web",
  "mobile": "Mobile",
};

const domainGradient: Record<string, string> = {
  "data-engineering": "linear-gradient(135deg, #14b8a6 0%, #3b82f6 100%)",
  "machine-learning": "linear-gradient(135deg, #8b5cf6 0%, #f472b6 100%)",
  "ai":               "linear-gradient(135deg, #f472b6 0%, #8b5cf6 100%)",
  "analytics":        "linear-gradient(135deg, #3b82f6 0%, #14b8a6 100%)",
  "web":              "linear-gradient(135deg, #14b8a6 0%, #8b5cf6 100%)",
  "mobile":           "linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%)",
};

// ── Stack dinámico desde proyectos ──────────────────────────────────────────
const techCategoryMap: Record<string, string> = {
  // Lenguajes
  "Python": "Lenguajes", "SQL": "Lenguajes", "TypeScript": "Lenguajes",
  "JavaScript": "Lenguajes", "Bash": "Lenguajes", "R": "Lenguajes",
  "Go": "Lenguajes", "Rust": "Lenguajes", "Java": "Lenguajes",
  // ML / IA
  "PyTorch": "ML / IA", "TensorFlow": "ML / IA", "scikit-learn": "ML / IA",
  "pandas": "ML / IA", "NumPy": "ML / IA", "LangChain": "ML / IA",
  "OpenAI": "ML / IA", "HuggingFace": "ML / IA", "Pinecone": "ML / IA",
  "Weaviate": "ML / IA", "FAISS": "ML / IA",
  // Backend
  "FastAPI": "Backend", "Node.js": "Backend", "Express": "Backend",
  "PostgreSQL": "Backend", "MySQL": "Backend", "Redis": "Backend",
  "MongoDB": "Backend", "Supabase": "Backend", "GraphQL": "Backend",
  "REST": "Backend", "Slack API": "Backend",
  // Frontend
  "React": "Frontend", "React Native": "Frontend", "Expo": "Frontend",
  "Next.js": "Frontend", "Vue": "Frontend", "Astro": "Frontend",
  "Recharts": "Frontend", "Tailwind": "Frontend",
  // Cloud & Data
  "AWS": "Cloud & Data", "GCP": "Cloud & Data", "Azure": "Cloud & Data",
  "BigQuery": "Cloud & Data", "Airflow": "Cloud & Data", "Docker": "Cloud & Data",
  "Kubernetes": "Cloud & Data", "Terraform": "Cloud & Data",
  "Power BI": "Cloud & Data", "dbt": "Cloud & Data", "Spark": "Cloud & Data",
};

const categoryOrder = ["Lenguajes", "ML / IA", "Backend", "Frontend", "Cloud & Data"];
const categoryColor: Record<string, string> = {
  "Lenguajes":   "var(--color-aurora-purple)",
  "ML / IA":     "var(--color-aurora-teal)",
  "Backend":     "var(--color-aurora-blue)",
  "Frontend":    "var(--color-cat-frontend)",
  "Cloud & Data":"var(--color-cat-cloud)",
  "Otros":       "var(--color-text-muted)",
};

// Techs únicas presentes en proyectos, preservando orden de primera aparición
const projectTechs = [...new Set(allProjects.flatMap((p) => p.data.stack))];

// Agrupar por categoría
const techsByCategory = new Map<string, string[]>();
for (const tech of projectTechs) {
  const cat = techCategoryMap[tech] ?? "Otros";
  if (!techsByCategory.has(cat)) techsByCategory.set(cat, []);
  techsByCategory.get(cat)!.push(tech);
}

// Ordenar categorías: primero las del orden definido, luego "Otros"
const stackGroups = [
  ...categoryOrder.filter((c) => techsByCategory.has(c)).map((c) => ({
    label: c,
    color: categoryColor[c],
    techs: techsByCategory.get(c)!,
  })),
  ...(techsByCategory.has("Otros") ? [{ label: "Otros", color: categoryColor["Otros"], techs: techsByCategory.get("Otros")! }] : []),
];
// ────────────────────────────────────────────────────────────────────────────

---

<BaseLayout title="JuanFe Martínez — Data Scientist & Engineer">
  <Nav />

  <main class="aurora-bg min-h-screen pt-20">
    <div class="relative z-10 mx-auto max-w-6xl px-6 py-16">

      <!-- Bento Grid -->
      <div class="bento-grid">

        <!-- Hero card — full width -->
        <div
          class="col-span-12 md:col-span-8 rounded-3xl p-8 md:p-12 mt-0 md:-mt-10 md:grid md:grid-cols-[auto_1fr] md:gap-x-8"
          style="background: var(--color-surface); border: 1px solid var(--color-border);"
        >
          <!-- Badge (fila 1, ancho completo) -->
          <div class="md:col-span-2 md:row-start-1">
            <p class="mb-0 text-sm font-medium" style="color: var(--color-aurora-purple);">
              Data Scientist & Data Engineer · Mercado Libre
            </p>
          </div>

          <!-- Avatar mobile (visible solo en mobile, centrado bajo el badge) -->
          <div class="flex justify-center mt-4 mb-1 md:hidden">
            <div
              class="p-0.5 rounded-full"
              style="background: linear-gradient(135deg, var(--color-aurora-purple), var(--color-aurora-teal));"
            >
              <div class="w-24 h-24 rounded-full overflow-hidden" style="background: var(--color-surface-2);">
                <img
                  src="/avatar.jpg"
                  alt="JuanFe Martínez"
                  class="w-full h-full object-cover object-center"
                />
              </div>
            </div>
          </div>

          <!-- Avatar (col 1, fila 2, desktop only) -->
          <div class="hidden md:flex md:items-center md:justify-center md:col-start-1 md:row-start-2 md:pt-6">
            <div
              class="p-0.5 rounded-full"
              style="background: linear-gradient(135deg, var(--color-aurora-purple), var(--color-aurora-teal));"
            >
              <div class="w-40 h-40 rounded-full overflow-hidden" style="background: var(--color-surface-2);">
                <img
                  src="/avatar.jpg"
                  alt="JuanFe Martínez"
                  class="w-full h-full object-cover object-center"
                />
              </div>
            </div>
          </div>

          <!-- H1 (col 2, fila 2) -->
          <div class="mt-3 md:mt-0 md:col-start-2 md:row-start-2 md:pt-3">
            <h1
              class="text-5xl font-bold leading-tight md:text-6xl lg:text-7xl"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              Hola, soy<br />
              <span
                style="background: linear-gradient(135deg, var(--color-aurora-purple), var(--color-aurora-teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
              >
                JuanFe
              </span>
            </h1>
          </div>

          <!-- Description + buttons (fila 3, ancho completo) -->
          <div class="mt-6 md:col-span-2 md:row-start-3">
            <p class="text-lg" style="color: var(--color-text-muted);">
              Curioso por naturaleza, apasionado por aprender, construir y compartir.
              Combino ciencia de datos e ingeniería para resolver problemas reales a gran escala.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="/projects"
                class="rounded-full px-6 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90"
                style="background: linear-gradient(135deg, var(--color-aurora-purple), var(--color-aurora-blue));"
              >
                Ver proyectos
              </a>
              <a
                href="/about"
                class="rounded-full px-6 py-2.5 text-sm font-semibold transition-colors"
                style="background: var(--color-surface-2); border: 1px solid var(--color-border); color: var(--color-text);"
              >
                Sobre mí
              </a>
            </div>
          </div>
        </div>

        <!-- Complexity Profile card -->
        <div
          class="col-span-12 md:col-span-4 rounded-3xl flex flex-col mt-0 md:-mt-10"
          style="background: var(--color-surface); border: 1px solid var(--color-border);"
        >
          <!-- Header -->
          <div class="relative px-6 pt-5 pb-2">
            <div
              class="absolute inset-0 opacity-20 pointer-events-none"
              style="background: radial-gradient(ellipse at 70% 0%, var(--color-aurora-teal) 0%, transparent 70%);"
            />
            <div class="relative flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Complexity Profile</span>
              <a href="/blog/the-scientist-complexity-framework" class="text-xs transition-opacity hover:opacity-70" style="color: var(--color-aurora-purple);">¿Qué es esto? →</a>
            </div>
            <p class="relative mt-2 text-xs leading-relaxed" style="color: var(--color-text-muted);">
              Cada proyecto clasificado por nivel de sistema y scored en cuatro dimensiones: arquitectura, datos, infraestructura e IA.
            </p>
          </div>

          <!-- Level distribution -->
          <div class="flex-1 flex flex-col justify-center px-5 py-4">
            <div class="flex items-center gap-1.5 mb-3">
              <p class="text-[9px] font-bold uppercase tracking-widest" style="color: var(--color-text-muted);">Distribución por nivel</p>
              <div class="matrix-help" tabindex="0">
                <span class="matrix-help-icon">?</span>
                <div class="matrix-help-popup">
                  <p class="matrix-help-section">Niveles · tipo de sistema</p>
                  <div style="display:flex; flex-direction:column; gap:2px;">
                    <span><b style="color:#22c55e">1</b> · Standalone Script</span>
                    <span><b style="color:#3b82f6">2</b> · Static App</span>
                    <span><b style="color:#eab308">3</b> · Basic Backend</span>
                    <span><b style="color:#f97316">4</b> · Distributed System</span>
                    <span><b style="color:#ef4444">5</b> · Complex Platform</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              {levelDist.map(({ level, count }) => (
                <div class="flex items-center gap-2.5">
                  <span
                    class="text-[10px] font-bold w-3 flex-shrink-0 text-right cursor-default"
                    title={levelName[level]}
                    style={`color: ${levelColor[level]};`}
                  >{level}</span>
                  <div class="flex-1 h-2 rounded-full overflow-hidden" style="background: var(--color-surface-2);">
                    <div
                      class="h-full rounded-full"
                      style={`width: ${count > 0 ? Math.max(count / maxLevelCount * 100, 5) : 0}%; background: ${levelColor[level]};`}
                    />
                  </div>
                  <span
                    class="text-[10px] font-bold w-3 flex-shrink-0 tabular-nums text-right"
                    style={`color: ${count > 0 ? levelColor[level] : "var(--color-border)"};`}
                  >{count}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Footer: matriz niveles × dimensiones -->
          <div class="px-4 pt-3 pb-4" style="border-top: 1px solid var(--color-border);">
            <div class="flex items-center gap-1.5 mb-2">
              <p class="text-[9px] font-bold uppercase tracking-widest" style="color: var(--color-text-muted);">Score promedio por nivel</p>
              <div class="matrix-help" tabindex="0">
                <span class="matrix-help-icon">?</span>
                <div class="matrix-help-popup">
                  <p class="matrix-help-section">Niveles de complejidad</p>
                  <div class="matrix-help-grid">
                    <span><b style="color:#22c55e">1</b> Standalone Script</span>
                    <span><b style="color:#3b82f6">2</b> Static App</span>
                    <span><b style="color:#eab308">3</b> Basic Backend</span>
                    <span><b style="color:#f97316">4</b> Distributed System</span>
                    <span><b style="color:#ef4444">5</b> Complex Platform</span>
                  </div>
                  <p class="matrix-help-section" style="margin-top:8px;">Dimensiones · score 0–3</p>
                  <div class="matrix-help-grid">
                    <span>🧱 <b>Arch</b> Diseño interno</span>
                    <span>📊 <b>Data</b> Complejidad datos</span>
                    <span>⚙️ <b>Infra</b> Deploy y operación</span>
                    <span>🤖 <b>AI</b> ML integrado</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="matrix-wrap" style="grid-template-columns: auto repeat(4, 1fr);">
              <!-- Esquina vacía + headers de dimensión -->
              <div />
              {matrixDims.map(({ emoji, short, key }) => (
                <div class="matrix-col-header" title={key}>{emoji} {short}</div>
              ))}
              <!-- Filas de nivel -->
              {projectMatrix.map(({ level, count, cells }) => (
                <>
                  <div class="matrix-row-label" title={levelDesc[level]} style={`color: ${levelColor[level]};`}>{level}</div>
                  {cells.map(({ avg }) => (
                    <div
                      class="matrix-cell"
                      style={avg !== null && avg > 0
                        ? `background: color-mix(in srgb, ${levelColor[level]} ${Math.round(avg / 3 * 70 + 10)}%, transparent); color: ${levelColor[level]};`
                        : ""}
                    >
                      {avg !== null && avg > 0 ? avg : null}
                    </div>
                  ))}
                </>
              ))}
            </div>
          </div>
        </div>

        <!-- Stack card -->
        <div
          class="col-span-12 md:col-span-4 rounded-3xl p-6 flex flex-col gap-5 relative overflow-hidden"
          style="background: var(--color-surface); border: 1px solid var(--color-border);"
        >
          <!-- Glow -->
          <div class="absolute inset-0 pointer-events-none opacity-10"
            style="background: radial-gradient(ellipse at 80% 20%, var(--color-aurora-purple) 0%, transparent 65%);" />

          <p class="relative text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Stack</p>

          <div class="relative flex flex-col gap-4">
            {stackGroups.map(({ label, color, techs }, gi) => (
              <div>
                <p class="mb-1.5 text-[10px] font-bold uppercase tracking-widest" style={`color: ${color};`}>{label}</p>
                <div class="flex flex-wrap gap-1.5" data-stack-group={gi}>
                  {techs.map((tech, ti) => (
                    <a
                      href={`/projects?tech=${encodeURIComponent(tech)}`}
                      class={`stack-pill rounded-full px-3 py-1 text-xs font-medium transition-opacity hover:opacity-70${ti >= 3 ? " stack-overflow hidden" : ""}`}
                      style={`background: color-mix(in srgb, ${color} 10%, transparent); border: 1px solid color-mix(in srgb, ${color} 25%, transparent); color: var(--color-text); text-decoration: none;`}
                    >
                      {tech}
                    </a>
                  ))}
                  {techs.length > 3 && (
                    <button
                      class="stack-toggle rounded-full px-3 py-1 text-xs font-medium transition-opacity hover:opacity-70"
                      data-group={gi}
                      data-extra={techs.length - 3}
                      style={`background: color-mix(in srgb, ${color} 10%, transparent); border: 1px solid color-mix(in srgb, ${color} 25%, transparent); color: ${color};`}
                    >
                      +{techs.length - 3} más
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Featured projects -->
        {projects.length > 0 && (
          <div class="col-span-12 md:col-span-8 rounded-3xl p-6" style="background: var(--color-surface); border: 1px solid var(--color-border);">
            <div class="mb-5 flex items-center justify-between">
              <p class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Proyectos recientes</p>
              <a href="/projects" class="text-xs" style="color: var(--color-aurora-purple);">Ver todos →</a>
            </div>
            <div class="grid grid-cols-1 gap-4">
              {projects.map((p) => (
                <a href={`/projects/${p.id}`} class="project-card group relative rounded-2xl overflow-hidden">

                  <!-- Capa imagen (revelada con wipe diagonal) -->
                  <div class="project-img absolute inset-0">
                    {p.data.image
                      ? <img src={p.data.image} alt={p.data.title} class="w-full h-full object-cover" />
                      : <div class="w-full h-full" style={`background: ${domainGradient[p.data.domain]};`} />
                    }
                  </div>

                  <!-- Overlay oscuro (aparece con la imagen) -->
                  <div class="project-overlay absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.80), rgba(0,0,0,0.25));" />

                  <!-- Contenido -->
                  <div class="relative z-10 flex items-center px-5 gap-4">
                    <!-- 30% izquierda: título + categoría -->
                    <div class="w-[30%] flex-shrink-0">
                      <span class="project-domain block text-[10px] font-bold uppercase tracking-widest mb-0.5">
                        {domainLabel[p.data.domain]}
                      </span>
                      <p class="project-title font-bold text-sm leading-snug" style="font-family: var(--font-display);">
                        {p.data.title}
                      </p>
                    </div>
                    <!-- Divisor -->
                    <div class="project-divider h-8 w-px flex-shrink-0" style="background: var(--color-border);" />
                    <!-- 70% derecha: descripción -->
                    <div class="flex-1 min-w-0">
                      <p class="project-desc text-sm leading-snug line-clamp-2">
                        {p.data.description}
                      </p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Blog card -->
        {posts.length > 0 && (
          <div
            class="col-span-12 rounded-3xl p-6"
            style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-aurora-purple) 8%, var(--color-surface)), var(--color-surface)); border: 1px solid var(--color-border);"
          >
            <div class="mb-5 flex items-center justify-between">
              <p class="text-xs font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Últimas entradas</p>
              <a href="/blog" class="text-xs" style="color: var(--color-aurora-purple);">Ver blog →</a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
              {posts.map((post) => (
                <a
                  href={`/blog/${post.id}`}
                  class="group flex flex-col justify-between gap-4 rounded-2xl p-5 transition-colors"
                  style="background: var(--color-surface); border: 1px solid var(--color-border);"
                >
                  <div>
                    {post.data.tags?.length > 0 && (
                      <span
                        class="mb-3 inline-block rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide"
                        style="background: color-mix(in srgb, var(--color-aurora-purple) 12%, transparent); color: var(--color-aurora-purple);"
                      >
                        {post.data.tags[0]}
                      </span>
                    )}
                    <p class="font-semibold leading-snug group-hover:underline" style="font-family: var(--font-display); color: var(--color-text);">{post.data.title}</p>
                    <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-text-muted);">{post.data.description}</p>
                  </div>
                  <div class="flex items-center justify-between">
                    <time class="text-xs" style="color: var(--color-text-muted);">
                      {new Date(post.data.date).toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric" })}
                    </time>
                    <span class="text-xs font-medium transition-transform group-hover:translate-x-1 inline-block" style="color: var(--color-aurora-purple);">Leer →</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>
  </main>

  <footer
    class="border-t px-6 py-10 text-center text-sm"
    style="border-color: var(--color-border); color: var(--color-text-muted);"
  >
    <p>&copy; {new Date().getFullYear()} JuanFeDS &mdash; Hecho con Astro</p>
  </footer>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".stack-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group   = btn.dataset.group!;
      const extra   = Number(btn.dataset.extra);
      const wrapper = document.querySelector(`[data-stack-group="${group}"]`)!;
      const hidden  = wrapper.querySelectorAll<HTMLElement>(".stack-overflow");
      const expanded = btn.dataset.expanded === "true";

      hidden.forEach((el) => el.classList.toggle("hidden", expanded));
      btn.dataset.expanded  = expanded ? "false" : "true";
      btn.textContent       = expanded ? `+${extra} más` : "ver menos";
    });
  });
</script>

<style>
  .matrix-wrap {
    display: grid;
    gap: 3px;
  }
  .matrix-col-header {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-text-muted);
    padding-bottom: 2px;
  }
  .matrix-row-label {
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    padding-right: 4px;
  }
  .matrix-cell {
    height: 22px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    border: 1px solid var(--color-border);
  }
  .matrix-empty {
    color: var(--color-border);
    font-weight: 400;
    font-size: 13px;
